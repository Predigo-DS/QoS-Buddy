# API Keys (Secrets)
# Note: Provider API keys should be in ai-services/agent/.env
# GROQ_API_KEY=gsk_...
# LOCAL_OPENAI_API_KEY=...
# TOKEN_FACTORY_API_KEY=...

# RAG Service Configuration
RAG_SERVICE_URL=http://rag:8001
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=qos_buddy
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=5

# Note: Provider configuration is centralized in config/providers.json
# To add a new provider:
# 1. Add provider config to config/providers.json
# 2. Add API key to ai-services/agent/.env
# 3. Restart agent container